DATABASE_URL=postgresql://user:password@localhost:5432/rennet
PORT=5000
# Optional values for npm run reset:db
# RESET_OWNER_PIN=1234
# RESET_MANAGER_USERNAME=manager
# RESET_MANAGER_PIN=4321

# Email provider config for platform-sent emails
#
# Option 1: SMTP (Infomaniak or any SMTP provider)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=mail.infomaniak.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=info@ren-net.lu
# SMTP_PASS=your-email-password
#
# Option 2: ZeptoMail
# EMAIL_PROVIDER=zeptomail
# ZEPTO_API_TOKEN=your-zepto-token
# ZEPTO_API_URL=https://api.zeptomail.eu/v1.1/email
# ZEPTO_FROM_ADDRESS=info@ren-net.lu
#
# Option 3: Resend
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM=info@ren-net.lu

# SMS provider config (Twilio) for platform-sent SMS reminders
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
